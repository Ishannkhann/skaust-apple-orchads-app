# OpenWeather API key for the orchard-detail weather widget.
# Copy this file to ".env" and fill in your real key.
#
# Get a free key at: https://openweathermap.org/api
# NOTE: newly created keys can take 2-3 hours to activate.
#
# The EXPO_PUBLIC_ prefix is required for Expo to expose the var to the app.
# Without a key set, the app falls back to mock weather data.
EXPO_PUBLIC_OPENWEATHER_API_KEY=
